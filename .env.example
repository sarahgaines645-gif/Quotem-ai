# Q's runtime environment.
# Copy this file to `.env` for local dev, or set these in Railway's
# variables panel for production. Never commit `.env`.

# ─── Required ───────────────────────────────────────────────────
# Together AI key — Q's main brain (DeepSeek V4 Pro for chat / agent /
# code / etc., plus Qwen3.5-9B for vision). Get one at together.ai.
TOGETHER_API_KEY=

# ─── Optional skills ────────────────────────────────────────────
# Each of these points at a Hugging Face Space that Q calls for the
# corresponding skill. If unset, the skill stays disabled and Q's UI
# shows a friendly "not configured" message. Set up the Spaces from
# the *-space folders in this repo when you want the skill live.

# Voice cloning / speech (Chatterbox).
CHATTERBOX_SPACE_URL=

# Image generation (Z-Image).
ZIMAGE_SPACE_URL=

# Image-to-SVG (StarVector).
STARVECTOR_SPACE_URL=

# Music generation (ACE-Step).
ACESTEP_SPACE_URL=

# Video generation (Wan 2.2).
WAN_SPACE_URL=

# ─── Web search (optional) ──────────────────────────────────────
# SerpAPI key for Q's agent skill. If unset, agent runs without web.
SERP_API_KEY=

# ─── Auth / Circle Mode ─────────────────────────────────────────
# A pepper used when hashing access keys. Generate a long random
# string and never change it after Q has registered users.
# MUST be set in production (>=16 chars) or every session is forgeable.
Q_AUTH_PEPPER=

# ─── Railway-set automatically ──────────────────────────────────
# RAILWAY_VOLUME_MOUNT_PATH — set by Railway when a volume is attached.
# Q stores his persistent memory + people registry under this path.
# Don't set manually unless you're testing volume behaviour locally.
